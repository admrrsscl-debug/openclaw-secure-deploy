{
  "$schema": "https://docs.openclaw.ai/schemas/openclaw.json",
  "meta": {
    "description": "Configuración segura para cliente – generada por SkillNest",
    "version": "1.0.0"
  },

  // 🔐 GATEWAY: solo escucha localmente, con autenticación
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "{{RANDOM_TOKEN}}"
    }
  },

  // 📞 CANALES: pairing estricto, lista blanca en grupos
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "groupAllowFrom": [],
      "mediaMaxMb": 50,
      "accounts": {
        "default": {
          "enabled": true,
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist"
        }
      }
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "allowFrom": [],
      "streaming": "off",
      "accounts": {
        "default": {
          "enabled": true,
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist",
          "streaming": "off"
        }
      }
    }
  },

  // 🛠️ HERRAMIENTAS: perfil restrictivo
  "tools": {
    "profile": "messaging",
    "deny": [
      "group:automation",
      "group:runtime",
      "group:fs",
      "sessions_spawn",
      "sessions_send"
    ],
    "fs": { "workspaceOnly": true },
    "exec": { "security": "deny", "ask": "always" },
    "elevated": { "enabled": false }
  },

  // 🤖 AGENTES: sandbox por defecto
  "agents": {
    "defaults": {
      "sandbox": { "mode": "all" },
      "workspace": "{{USER_HOME}}/.openclaw/workspace",
      "model": { "primary": "deepseek/deepseek-chat" },
      "compaction": { "mode": "safeguard" }
    }
  },

  // 🧠 MODELOS: DeepSeek como predeterminado (fácil de cambiar)
  "models": {
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "{{DEEPSEEK_API_KEY}}",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat",
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek Reasoner",
            "reasoning": true,
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  // ⚙️ COMANDOS NATIVOS
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  }
}